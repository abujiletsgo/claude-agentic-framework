{
  "_comment": "v4.1: Full lifecycle hooks, async non-blocking, role-based team, session cost tracking",
  "_cache_note": "Extended cache TTL active (1-hour via ANTHROPIC_CUSTOM_HEADERS). Default is 5 min — 1-hour TTL ensures project context cache hits across all agents in long pipelines. Cache minimums: Sonnet 4.6=2048 tokens, Opus/Haiku=4096 tokens.",
  "version": "1.0",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_CUSTOM_HEADERS": "anthropic-beta: extended-cache-ttl-2025-04-11,advisor-tool-2026-03-01",
    "PATH": "/Users/tomkwon/.local/bin:/opt/homebrew/bin:/usr/bin:/Users/tomkwon/.cargo/bin:/usr/local/bin:/bin"
  },
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Task(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "*"
    ]
  },
  "permissionMode": "bypassPermissions",
  "sandbox": {
    "enabled": false
  },
  "hooks": {

    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py --failure-threshold 5 -- uv run --no-project __REPO_DIR__/global-hooks/framework/session/session_startup.py",
            "timeout": 60,
            "statusMessage": "Initializing session..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks session-recorder",
            "timeout": 5
          }
        ]
      }
    ],

    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/session/session_lock_manager.py",
            "timeout": 5,
            "async": true,
            "_comment": "Release all session locks on exit"
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/korean/kr_mode.py",
            "timeout": 8
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/caddy/analyze_request.py",
            "timeout": 10,
            "statusMessage": "Analyzing request..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/caddy/auto_delegate.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks epistemic-guard",
            "timeout": 5,
            "_comment": "Rust: Inject epistemic discipline reminder for analysis/interpretation prompts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks enforce-orchestrate",
            "timeout": 5,
            "_comment": "Rust: Enforce Skill tool invocation when /orchestrate is detected"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks session-recorder",
            "timeout": 5
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks orchestrator-tool-guard",
            "timeout": 5,
            "_comment": "Rust: Block orchestrator from using file/search/exec tools directly — forces delegation to subagents"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/session/session_lock_manager.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks damage-control",
            "timeout": 5,
            "_comment": "Rust: 10.6x faster security gate"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/automation/auto_review_team.py",
            "timeout": 5
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/session/session_lock_manager.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks context-bundle-logger",
            "timeout": 8,
            "async": true,
            "_comment": "Rust: ASYNC bundle logging (CB built-in)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks auto-error-analyzer",
            "timeout": 8,
            "_comment": "Rust: error classification (CB built-in)"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks auto-refine",
            "timeout": 6,
            "_comment": "Rust: auto-refine suggestions (CB built-in)"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/context/auto_context_manager.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks --cb auto-escalate",
            "timeout": 5,
            "async": true,
            "_comment": "Rust: ASYNC: escalation advice delivered on next turn"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/notifications/auto_voice_notifications.py",
            "timeout": 5,
            "async": true,
            "_comment": "ASYNC: voice notifications are fire-and-forget"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/automation/auto_team_review.py",
            "timeout": 5,
            "async": true,
            "_comment": "ASYNC: team review triggers don't need to block"
          }
        ]
      },
      {
        "matcher": "Bash|Write",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks --cb auto-fact-extractor",
            "timeout": 5,
            "async": true,
            "_comment": "Rust: ASYNC: fact extraction writes to disk, result delivered next turn"
          }
        ]
      }
    ],

    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks --cb auto-error-analyzer",
            "timeout": 10
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/session/session_lock_manager.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/validators/check_lthread_progress.py",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks auto-memory-writer",
            "timeout": 10,
            "_comment": "Rust: write session summary to .claude/MEMORY.md"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/facts/validate_facts.py",
            "timeout": 5,
            "_comment": "Layer 2: prune stale facts from FACTS.md"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/automation/auto_dependency_audit.py",
            "timeout": 15,
            "async": true,
            "_comment": "Moved from PostToolUse:Write|Edit — run once per session instead of per-write"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/automation/auto_skill_generator.py",
            "timeout": 10,
            "_comment": "Analyze session patterns and auto-generate skills"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/guardrails/circuit_breaker_wrapper.py -- uv run --no-project __REPO_DIR__/global-hooks/framework/automation/activity_logger.py",
            "timeout": 8,
            "async": true,
            "_comment": "ASYNC: append session summary to activity_log.jsonl for dashboard"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks voice-done",
            "timeout": 5,
            "async": true,
            "_comment": "Rust: ASYNC voice notification is fire-and-forget"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/health/hook_health_monitor.py",
            "timeout": 10,
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks session-recorder",
            "timeout": 5
          }
        ]
      }
    ],

    "StopFailure": [
      {
        "matcher": "rate_limit|authentication_failed|billing_error|server_error|max_output_tokens|unknown",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks stop-failure-recovery",
            "timeout": 5,
            "_comment": "Rust: Handle all API failures with typed recovery advice"
          }
        ]
      }
    ],

    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks subagent-tracker",
            "timeout": 5,
            "async": true,
            "_comment": "Rust: v4.0: Track subagent spawning with agent_id/agent_type"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks orch-depth-tracker",
            "timeout": 5,
            "_comment": "Rust: Track orchestration nesting depth for tool guard"
          }
        ]
      }
    ],

    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks subagent-tracker",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks orch-depth-tracker",
            "timeout": 5,
            "_comment": "Rust: Track orchestration nesting depth for tool guard"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks session-cost-tracker",
            "timeout": 8,
            "async": true,
            "_comment": "Rust: ASYNC: reads agent transcript + records cost — fire-and-forget"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/hooks_SubagentStop/lead_result_store.py",
            "timeout": 8
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/memory/lead_memory_writer.py",
            "timeout": 8
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks voice-done",
            "timeout": 5,
            "async": true,
            "_comment": "Rust: ASYNC contextual voice notification on subagent completion"
          }
        ]
      }
    ],

    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks task-quality-gate",
            "timeout": 10,
            "_comment": "Rust: Validate task completion criteria before marking done"
          }
        ]
      }
    ],

    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/automation/project_fingerprint.py",
            "timeout": 10,
            "_comment": "v4.0: Auto-detect project stack, load relevant instincts, configure per-project"
          }
        ]
      }
    ],

    "FileChanged": [
      {
        "matcher": "package.json|pyproject.toml|Cargo.toml|go.mod",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks file-watcher",
            "timeout": 10,
            "async": true,
            "_comment": "Rust: React to dependency file changes"
          }
        ]
      }
    ],

    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks audit-config-change",
            "timeout": 5,
            "_comment": "Rust: Audit configuration changes for security"
          }
        ]
      }
    ],

    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --no-project __REPO_DIR__/global-hooks/framework/context/pre_compact_preserve.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_DIR__/target/release/caf-hooks post-compact-verify",
            "timeout": 5,
            "async": true,
            "_comment": "Rust: Verify critical state survived compaction"
          }
        ]
      }
    ]

  },
  "mcpServers": {
    "officecli": {
      "command": "officecli",
      "args": ["mcp"],
      "_comment": "OfficeCLI: create/read/edit Word, Excel, PowerPoint — used by /docs skill"
    },
    "papers": {
      "command": "uv",
      "args": ["run", "--with", "paper-search-mcp", "python", "-m", "paper_search_mcp.server"],
      "env": {
        "PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY": "${SEMANTIC_SCHOLAR_API_KEY:-}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "papersflow": {
      "type": "url",
      "url": "https://doxa.papersflow.ai/mcp",
      "transport": "streamable-http"
    },
    "sourcegraph": {
      "command": "sourcegraph-mcp",
      "env": {
        "SOURCEGRAPH_URL": "https://sourcegraph.com",
        "SOURCEGRAPH_TOKEN": "${SRC_ACCESS_TOKEN}"
      }
    }
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "uv run --no-project __REPO_DIR__/global-status-lines/mastery/status_line_custom.py",
    "padding": 0
  }
}
