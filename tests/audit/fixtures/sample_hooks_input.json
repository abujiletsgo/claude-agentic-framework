      "stdout": "FAILED tests/test_auth.py::test_login - AssertionError: expected True, got False\n1 failed in 0.43s",
      "stderr": "",
      "exit_code": 1
    },
    "session_id": "audit-test-001"
  },
  "PostToolUse_Edit_success": {
    "hookEventName": "PostToolUse",
    "tool_name": "Edit",
    "tool_input": {"file_path": "/tmp/test-audit/src/app.py"},
