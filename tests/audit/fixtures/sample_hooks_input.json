  },
  "PreToolUse_Bash_safe": {
    "hookEventName": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "echo hello world"},
    "session_id": "audit-test-001"
  },
  "PreToolUse_Bash_dangerous": {
    "hookEventName": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "rm -rf /tmp/test-audit-deleteme"},
    "session_id": "audit-test-001"
  },
  "PreToolUse_Bash_git_reset": {
    "hookEventName": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "git reset --hard HEAD~1"},
    "session_id": "audit-test-001"
  },
  "PreToolUse_Edit_safe": {
    "hookEventName": "PreToolUse",
    "tool_name": "Edit",
    "tool_input": {"file_path": "/tmp/test-audit/src/app.py", "old_string": "x = 1", "new_string": "x = 2"},
    "session_id": "audit-test-001"
  },
  "PreToolUse_Write_safe": {
    "hookEventName": "PreToolUse",
    "tool_name": "Write",
